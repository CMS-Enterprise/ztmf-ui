# Environment Variables
#
# For local development setup, see .env.development.example
# Copy that file to .env.development.local and configure for your local environment
#
# This .env.example file is kept for backward compatibility
# Modern Vite apps should use .env.development.local for local dev configuration

TOKEN = ''
PROXY_URI = ''

# Development banner overrides (optional). Blank by design in the repo; the
# deployed dev environment injects real values from CI secrets during a testing
# window and clears them afterward. See .github/workflows/ui.yml.
VITE_DEV_BANNER_MESSAGE = ''
VITE_DEV_FEEDBACK_URL = ''
VITE_DEV_CONTACT_EMAIL = ''